{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.ts",
    "src/browser.ts",
    "src/**/*.test.{js,ts}",
    "dev/parity/**/*.{js,ts}",
    "benchmarks/**/*.{js,mjs}"
  ],
  "project": ["src/**/*.{ts,js}"],
  "ignore": [
    "**/*.test.js",
    "**/*.test.ts",
    "src/SearchableMap/**",
    "src/radixTree.ts",
    "src/PackedRadixTree/fromRadixTree.ts",
    "src/PackedRadixTree/devStringIterators.ts",
    "src/binaryEncode.ts",
    "src/binaryMsv5EncodeShared.ts",
    "src/binaryBytes.ts",
    "src/internal/frozenInternals.ts",
    "src/msv5/binaryMsv5Constants.ts"
  ],
  "ignoreBinaries": ["make"],
  "ignoreExportsUsedInFile": true
}
